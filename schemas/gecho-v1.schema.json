{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/PalmEmanuel/gEcho/schemas/gecho-v1.schema.json",
  "title": "gEcho Workbook",
  "description": "A gEcho workbook recording VS Code interactions for replay and GIF generation",
  "type": "object",
  "required": ["version", "metadata", "steps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1.0"],
      "description": "Workbook schema version"
    },
    "metadata": {
      "$ref": "#/$defs/WorkbookMetadata"
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/Step" },
      "description": "Array of steps to execute during replay"
    }
  },
  "$defs": {
    "WorkbookMetadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "description": "Metadata describing the workbook",
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name for this workbook"
        },
        "description": {
          "type": "string",
          "description": "Optional description of what the workbook demonstrates"
        },
        "windowSize": {
          "type": "object",
          "required": ["width", "height"],
          "additionalProperties": false,
          "description": "Target VS Code window dimensions for replay",
          "properties": {
            "width": {
              "type": "integer",
              "minimum": 1,
              "description": "Window width in pixels"
            },
            "height": {
              "type": "integer",
              "minimum": 1,
              "description": "Window height in pixels"
            }
          }
        },
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of when this workbook was created"
        },
        "version": {
          "type": "string",
          "description": "User-defined version string for the workbook"
        }
      }
    },
    "Step": {
      "type": "object",
      "required": ["type"],
      "description": "A single step in the workbook",
      "oneOf": [
        { "$ref": "#/$defs/TypeStep" },
        { "$ref": "#/$defs/CommandStep" },
        { "$ref": "#/$defs/KeyStep" },
        { "$ref": "#/$defs/SelectStep" },
        { "$ref": "#/$defs/WaitStep" },
        { "$ref": "#/$defs/OpenFileStep" },
        { "$ref": "#/$defs/PasteStep" },
        { "$ref": "#/$defs/ScrollStep" }
      ]
    },
    "TypeStep": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "description": "Type text character by character into the active editor",
      "properties": {
        "type": {
          "type": "string",
          "const": "type",
          "description": "Step type identifier"
        },
        "text": {
          "type": "string",
          "description": "Text to type character by character"
        },
        "delay": {
          "type": "number",
          "minimum": 0,
          "description": "Per-character delay in milliseconds"
        }
      }
    },
    "CommandStep": {
      "type": "object",
      "required": ["type", "id"],
      "additionalProperties": false,
      "description": "Execute a VS Code command by ID",
      "properties": {
        "type": {
          "type": "string",
          "const": "command",
          "description": "Step type identifier"
        },
        "id": {
          "type": "string",
          "description": "VS Code command ID to execute (e.g. workbench.action.files.save)"
        },
        "args": {
          "description": "Optional arguments to pass to the command"
        }
      }
    },
    "KeyStep": {
      "type": "object",
      "required": ["type", "key"],
      "additionalProperties": false,
      "description": "Simulate a keyboard key press",
      "properties": {
        "type": {
          "type": "string",
          "const": "key",
          "description": "Step type identifier"
        },
        "key": {
          "type": "string",
          "description": "Key or key combination to press (e.g. escape, ctrl+z, shift+alt+f)"
        }
      }
    },
    "SelectStep": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "description": "Set the editor selection with anchor and active positions, or multiple selections for multi-cursor",
      "anyOf": [
        { "required": ["anchor", "active"] },
        { "required": ["selections"] }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "select",
          "description": "Step type identifier"
        },
        "anchor": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 2,
          "maxItems": 2,
          "description": "Anchor position as [line, character] (zero-based)"
        },
        "active": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 2,
          "maxItems": 2,
          "description": "Active (cursor) position as [line, character] (zero-based)"
        },
        "selections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["anchor", "active"],
            "additionalProperties": false,
            "properties": {
              "anchor": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0 },
                "minItems": 2,
                "maxItems": 2,
                "description": "Anchor position as [line, character] (zero-based)"
              },
              "active": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0 },
                "minItems": 2,
                "maxItems": 2,
                "description": "Active (cursor) position as [line, character] (zero-based)"
              }
            }
          },
          "description": "Array of selections for multi-cursor support"
        }
      }
    },
    "WaitStep": {
      "type": "object",
      "required": ["type", "ms"],
      "additionalProperties": false,
      "description": "Pause execution for a specified duration",
      "properties": {
        "type": {
          "type": "string",
          "const": "wait",
          "description": "Step type identifier"
        },
        "ms": {
          "type": "number",
          "minimum": 0,
          "description": "Duration to wait in milliseconds"
        },
        "until": {
          "type": "string",
          "enum": ["idle"],
          "description": "Optional condition to wait for before continuing"
        }
      }
    },
    "OpenFileStep": {
      "type": "object",
      "required": ["type", "path"],
      "additionalProperties": false,
      "description": "Open a file in the editor",
      "properties": {
        "type": {
          "type": "string",
          "const": "openFile",
          "description": "Step type identifier"
        },
        "path": {
          "type": "string",
          "description": "Path to the file to open, relative to the workspace root"
        }
      }
    },
    "PasteStep": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "description": "Paste text into the active editor as if from the clipboard",
      "properties": {
        "type": {
          "type": "string",
          "const": "paste",
          "description": "Step type identifier"
        },
        "text": {
          "type": "string",
          "description": "Text to paste into the editor"
        }
      }
    },
    "ScrollStep": {
      "type": "object",
      "required": ["type", "direction", "lines"],
      "additionalProperties": false,
      "description": "Scroll the active editor up or down",
      "properties": {
        "type": {
          "type": "string",
          "const": "scroll",
          "description": "Step type identifier"
        },
        "direction": {
          "type": "string",
          "enum": ["up", "down"],
          "description": "Direction to scroll"
        },
        "lines": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of lines to scroll"
        }
      }
    }
  }
}
