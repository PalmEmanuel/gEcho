{
  "name": "gEcho",
  "displayName": "gEcho",
  "description": "Record, replay, and generate reproducible GIFs from VS Code interactions.",
  "version": "0.0.1",
  "publisher": "PalmEmanuel",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1E1432",
    "theme": "dark"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/emanuelpalm/gEcho.git"
  },
  "bugs": {
    "url": "https://github.com/emanuelpalm/gEcho/issues"
  },
  "homepage": "https://github.com/emanuelpalm/gEcho#readme",
  "keywords": ["recording", "gif", "replay", "automation", "demo", "screencast", "workbook"],
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other",
    "Testing",
    "Debuggers"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gecho.startEchoRecording",
        "title": "gEcho: Start Echo Recording"
      },
      {
        "command": "gecho.stopEchoRecording",
        "title": "gEcho: Stop Echo Recording"
      },
      {
        "command": "gecho.startGifRecording",
        "title": "gEcho: Start GIF Recording"
      },
      {
        "command": "gecho.stopGifRecording",
        "title": "gEcho: Stop GIF Recording"
      },
      {
        "command": "gecho.replayWorkbook",
        "title": "gEcho: Replay Workbook"
      },
      {
        "command": "gecho.replayAsGif",
        "title": "gEcho: Replay as GIF"
      }
    ],
    "configuration": {
      "title": "gEcho",
      "properties": {
        "gecho.ffmpegPath": {
          "type": "string",
          "default": "ffmpeg",
          "description": "Path to ffmpeg binary."
        },
        "gecho.outputDirectory": {
          "type": "string",
          "default": "~/gecho-recordings",
          "description": "Where to save recordings."
        },
        "gecho.gif.fps": {
          "type": "number",
          "default": 10,
          "description": "Frames per second for GIF output."
        },
        "gecho.gif.width": {
          "type": "number",
          "default": 1920,
          "description": "GIF output width (height scales proportionally)."
        },
        "gecho.gif.quality": {
          "type": "string",
          "default": "high",
          "enum": [
            "high",
            "balanced",
            "small"
          ],
          "description": "GIF quality preset."
        },
        "gecho.replay.speed": {
          "type": "number",
          "default": 1.0,
          "description": "Replay speed multiplier."
        }
      }
    },
    "languages": [
      {
        "id": "json",
        "extensions": [
          ".gecho.json"
        ],
        "aliases": ["gEcho Workbook"]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.gecho.json",
        "url": "./schemas/gecho-v1.schema.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "build": "npm run compile",
    "watch": "tsc -watch -p ./",
    "check-types": "tsc --noEmit",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^7.14.0",
    "@typescript-eslint/parser": "^7.14.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.2.0",
    "eslint": "^8.56.0",
    "mocha": "^10.4.0",
    "typescript": "^5.4.0"
  }
}
